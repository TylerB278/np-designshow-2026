---
import { getCollection } from "astro:content";
import slugify from "../helpers/slugify";
import { Image } from "astro:assets";
const allProjects = await getCollection("people");
const allProjectsSorted = allProjects.sort((a, b) => {
  const aLast = a.data.name.split(" ").pop() || "";
  const bLast = b.data.name.split(" ").pop() || "";
  return aLast > bLast ? 1 : -1;
});
---
<div id="navSide"></div>
<div class="project-grid">
  {
    allProjectsSorted.map((project) => {
      const projectSlug = slugify(project.data.title);
      const projectUrl = `/projects/${projectSlug}/`;
      return (
        <article class="project-card">
          <Image
            transition:name={`thumb-${projectSlug}`}
            width={1000}
            quality={60}
            class="project-image"
            src={project.data.thumbnail.src}
            alt=""
          />
          <a class="project-title" href={projectUrl}>
            {project.data.title}
          </a>
          <p class="person-name">{project.data.name}</p>
        </article>
      );
    })
  }
</div>

<script>
  window.addEventListener('scroll', function() {
  const navbar = document.getElementById('navSide');
  if (window.scrollY > 1000) // Shows after 100px of scrolling
  { 
    navbar?.classList.add('show');
  } else {
    navbar?.classList.remove('show');
  }
});
</script>

<style>
  #navSide{
    position: fixed;
    top: 10%;
    left: -410px;
    width: 300px;
    height: 80vh;
    background-color: var(--color-accent-b);
    transition: left 0.5s;
  }#navSide.show { left: 20px; }

  .project-grid {
    /* max-width: 1000px; */
    /* width: calc(100% - 8 * var(--size-page-margin)); */
    width: 100%;
    padding: 20px;
    padding-left: 350px;
    display: grid;
    align-items: top;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin: var(--size-page-margin) 0;
  }
  @media screen and (min-width: 450px) {
    .project-grid {
      grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    }
  }

  @media (max-width: 850px) {
    #navSide{ display: none; }
    .project-grid{ 
      padding-left: 20px; 
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    }
    
  }
  .project-card {
    /* max-width: 600px; */
    position: relative;
    color: var(--color-accent-b);
  }
  .project-card:hover,
  .project-card:focus-within {
    /* background-color: var(--color-background); */
    color: var(--color-accent-a);
    /* outline: 1px solid var(--color-accent-a); */
  }

  .project-image {
    width: 100%;
    height: auto;
    aspect-ratio: 192 / 126;
    object-fit: cover;
    background-color: var(--color-accent-a);
  }
  .person-name {
    font-size: 1.5rem;
    font-family: "Sligoil", serif;
  }
  .project-title {
    font-family: "Compagnon", monospace;
    font-size: 1.25rem;
    text-decoration: none;
    text-wrap: balance;
  }
  .project-title::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s;
  }

  .project-title:focus-visible::before {
    outline: 2px solid var(--color-accent-a);
    outline-offset: 2px;
  }

  .project-title:focus,
  .project-title:focus-visible {
    outline: none;
    box-shadow: none;
  }

  @media (max-width: 850px) {
    .navSide{
      display: none;
    }

    /* .project-grid{
      max-width: var(--size-page-width);
      width: calc(100% - 2 * var(--size-page-margin));
    } */
  }
</style>
